# Which provider the Interpretation Engine tries first: "openrouter"
# (default) or "ollama". Whichever one isn't primary is still used as an
# automatic fallback if the primary call fails, so it's fine to configure
# both.
#
# CAVEAT: the interpretation grounding filters (src/interpretation/engine.py)
# were calibrated against Ollama/llama3.2:3b specifically -- see
# engine/decisions.md. Running primarily against OpenRouter means most
# turns use a model that hasn't been through that same n=10 validation.
LLM_PROVIDER=openrouter

# Generic key, used as a fallback for any provider below that doesn't have
# its own key set. Handy if you only want to manage one secret.
LLM_API_KEY=

# --- OpenRouter (https://openrouter.ai/keys) ---
OPENROUTER_API_KEY=
# `openrouter/free` -- OpenRouter's own auto-router: it randomly selects
# a free model per-request from whatever's currently available, filtered
# to models that support the request's needed features (structured
# outputs, tool calling, etc.), rather than pinning to one specific free
# model that might individually be overloaded. Confirmed $0.00 cost and
# capabilities via OpenRouter's own pricing page 2026-07-05. Rate limits
# are still the free tier's: 50 req/day with no credits loaded (1,000/day
# once $10+ has been loaded) and 20 req/minute -- Interpretation +
# Judgment is 2 calls per conversation turn, so the no-credit tier caps
# out around 25 turns/day. Set your own model here to pin a specific one
# instead.
OPENROUTER_MODEL=openrouter/free
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Ollama (local, no key required) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
# OLLAMA_TIMEOUT=180
# Seconds to wait for a response. Default (180) is tuned for a local dev
# machine -- CPU-only environments (e.g. CI runners with no GPU) may need
# a higher value; see .github/workflows/single-turn-smoketest.yml.

# --- Instrumentation (src/instrumentation/usage.py) ---
# Off by default -- measurement only, no effect on normal runs. Set to 1
# to record token/cost/latency per LLM call and print a per-turn summary
# from conversation_runner.py / scripts/run_worldstate_walkthrough.py.
# Turn this on for evaluation runs (see
# engine/specs/judgment-v2-evaluation-design.md), leave it off otherwise.
CONFIDANT_TRACK_USAGE=0
