# Which provider StateUpdater tries first: "openrouter" (default) or "ollama".
# Whichever one isn't primary is still used as an automatic fallback if the
# primary call fails, so it's fine to configure both.
LLM_PROVIDER=openrouter

# Generic key, used as a fallback for any provider below that doesn't have
# its own key set. Handy if you only want to manage one secret.
LLM_API_KEY=

# --- OpenRouter (https://openrouter.ai/keys) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Ollama (local, no key required) ---
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1
